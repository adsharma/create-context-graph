{% raw %}"""LadybugDB context graph client."""

from __future__ import annotations

import asyncio
import json as _json
import logging
import uuid as _uuid
from datetime import datetime, timezone
from pathlib import Path

import real_ladybug as lb


logger = logging.getLogger(__name__)

_db: lb.Database | None = None
_conn: lb.Connection | None = None


# ---------------------------------------------------------------------------
# Result collector — captures Cypher results from agent tool calls so the
# chat endpoint can attach them as graph_data without modifying agent templates.
# ---------------------------------------------------------------------------

class CypherResultCollector:
    """Collects Cypher query results for downstream graph visualization.

    When an event queue is attached (via ``set_event_queue``), the collector
    also pushes SSE-ready event dicts to the queue so the streaming endpoint
    can forward them to the frontend in real time.
    """

    def __init__(self):
        self.results: list[dict] = []
        self.tool_calls: list[dict] = []
        self._event_queue: asyncio.Queue | None = None

    # -- event queue management ------------------------------------------------

    def set_event_queue(self, queue: asyncio.Queue) -> None:
        """Attach an asyncio.Queue for SSE streaming."""
        self._event_queue = queue

    def clear_event_queue(self) -> None:
        """Detach the event queue."""
        self._event_queue = None

    def _push_event(self, event: str, data: dict) -> None:
        """Push an SSE event to the queue if one is attached."""
        if self._event_queue is not None:
            self._event_queue.put_nowait({"event": event, "data": data})

    # -- tool call events ------------------------------------------------------

    def emit_tool_start(self, name: str, inputs: dict) -> None:
        """Emit a tool_start SSE event."""
        self._push_event("tool_start", {"name": name, "inputs": inputs})

    def emit_text_delta(self, text: str) -> None:
        """Emit a text_delta SSE event."""
        self._push_event("text_delta", {"text": text})

    def emit_done(self, response_text: str, session_id: str = "") -> None:
        """Emit a done SSE event."""
        self._push_event("done", {"response": response_text, "session_id": session_id})

    # -- existing collection methods -------------------------------------------

    def collect(self, records: list[dict]) -> None:
        self.results.extend(records)

    def collect_tool_call(self, name: str, inputs: dict, output_preview: str = "") -> None:
        self.tool_calls.append({
            "name": name,
            "inputs": inputs,
            "output_preview": output_preview[:500],
        })
        # Emit tool_end SSE event with the graph data collected so far
        self._push_event("tool_end", {
            "name": name,
            "inputs": inputs,
            "output_preview": output_preview[:500],
            "graph_data": {"results": list(self.results)},
        })

    def drain(self) -> list[dict]:
        results = list(self.results)
        self.results.clear()
        return results

    def drain_tool_calls(self) -> list[dict]:
        calls = list(self.tool_calls)
        self.tool_calls.clear()
        return calls


_collector = CypherResultCollector()


def get_collector() -> CypherResultCollector:
    """Get the global result collector."""
    return _collector


def _result_to_dicts(result) -> list[dict]:
    """Convert a LadybugDB query result into a list of dicts."""
    records = []
    col_names = result.get_column_names()
    while result.has_next():
        row = result.get_next()
        record = {}
        for i, name in enumerate(col_names):
            val = row[i]
            # Convert LadybugDB node/rel objects to dicts if needed
            if hasattr(val, "get_properties"):
                props = val.get_properties()
                if hasattr(val, "get_label"):
                    props["_label"] = val.get_label()
                record[name] = props
            else:
                record[name] = val
        records.append(record)
    return records


def is_connected() -> bool:
    """Check if LadybugDB is available."""
    if _conn is None:
        return False
    try:
        result = _conn.execute("RETURN 1 AS n")
        while result.has_next():
            result.get_next()
        return True
    except Exception:
        return False


async def connect_db() -> None:
    """Connect to LadybugDB (embedded)."""
    global _db, _conn
    from app.config import settings

    db_path = settings.ladybug_db_path
    Path(db_path).parent.mkdir(parents=True, exist_ok=True)

    _db = lb.Database(db_path)
    _conn = lb.Connection(_db)
    logger.info("LadybugDB connected at %s", db_path)


async def close_db() -> None:
    """Close LadybugDB connection."""
    global _db, _conn
    _conn = None
    _db = None


# ---------------------------------------------------------------------------
# Conversation memory — stored natively in LadybugDB
# ---------------------------------------------------------------------------


async def get_conversation_history(session_id: str, limit: int = 20) -> list[dict]:
    """Retrieve conversation history for a session."""
    if _conn is None:
        return []
    try:
        result = await asyncio.to_thread(
            _conn.execute,
            "MATCH (m:ConversationMessage) WHERE m.session_id = $sid "
            "RETURN m.role AS role, m.content AS content "
            "ORDER BY m.created_at LIMIT $lim",
            {"sid": session_id, "lim": limit},
        )
        return _result_to_dicts(result)
    except Exception as e:
        logger.warning("Failed to retrieve conversation history: %s", e)
        return []


async def store_message(session_id: str, role: str, content: str) -> None:
    """Store a message in conversation history."""
    if _conn is None:
        return
    try:
        msg_id = str(_uuid.uuid4())
        await asyncio.to_thread(
            _conn.execute,
            "CREATE (m:ConversationMessage {"
            "msg_id: $mid, session_id: $sid, role: $role, "
            "content: $content, created_at: $ts})",
            {
                "mid": msg_id,
                "sid": session_id,
                "role": role,
                "content": content,
                "ts": datetime.now(timezone.utc).isoformat(),
            },
        )
    except Exception as e:
        logger.warning("Failed to store message: %s", e)


def get_connection() -> lb.Connection:
    """Get the LadybugDB connection instance."""
    if _conn is None:
        raise RuntimeError("LadybugDB not connected. Call connect_db() first.")
    return _conn


async def execute_cypher(
    query: str,
    parameters: dict | None = None,
    *,
    collect: bool = True,
    tool_name: str | None = None,
    timeout: float | None = 30.0,
) -> list[dict]:
    """Execute a Cypher query and return results as dicts."""
    conn = get_connection()
    if tool_name and collect:
        _collector.emit_tool_start(tool_name, parameters or {})

    def _run():
        if parameters:
            result = conn.execute(query, parameters)
        else:
            result = conn.execute(query)
        return _result_to_dicts(result)

    records = await asyncio.to_thread(_run)

    if collect:
        _collector.collect(records)
        if tool_name:
            _collector.collect_tool_call(
                tool_name, parameters or {}, str(records[:2])
            )
    return records


async def search_entities(query: str, label: str | None = None, limit: int = 20) -> list[dict]:
    """Full-text search across entities."""
    # LadybugDB doesn't support dynamic labels in MATCH the same way,
    # so we query all nodes with a name property and filter in Python if needed.
    cypher = """
    MATCH (n)
    WHERE n.name IS NOT NULL
      AND (lower(n.name) CONTAINS lower($query)
           OR lower(coalesce(n.description, '')) CONTAINS lower($query))
    RETURN n
    LIMIT $limit
    """
    results = await execute_cypher(cypher, {"query": query, "limit": limit})
    if label:
        results = [r for r in results if r.get("n", {}).get("_label") == label]
    return results


async def get_entity_graph(entity_name: str, depth: int = 2) -> dict:
    """Get the subgraph around an entity."""
    cypher = """
    MATCH (n)
    WHERE lower(n.name) = lower($name)
    OPTIONAL MATCH (n)-[r]-(connected)
    RETURN n, connected
    """
    results = await execute_cypher(cypher, {"name": entity_name})
    if results:
        return results[0]
    return {"nodes": [], "relationships": []}


async def get_schema() -> dict:
    """Get the graph database schema (table names)."""
    try:
        result = await execute_cypher("CALL show_tables() RETURN *")
        labels = [r.get("name", "") for r in result if r.get("type") == "NODE"]
        rel_types = [r.get("name", "") for r in result if r.get("type") == "REL"]
        return {"labels": labels, "relationship_types": rel_types}
    except Exception:
        return {"labels": [], "relationship_types": []}


async def get_schema_visualization() -> dict:
    """Get the graph schema as nodes and relationships for visualization."""
    return await get_schema()


async def expand_node(element_id: str) -> dict:
    """Get immediate neighbors of a node for graph expansion.

    In LadybugDB, we use the node's name as identifier since there's no elementId().
    """
    cypher = """
    MATCH (n) WHERE n.name = $name
    OPTIONAL MATCH (n)-[r]-(m)
    RETURN n, m
    """
    results = await execute_cypher(cypher, {"name": element_id}, collect=False)
    return {"results": results}


async def reset_database() -> None:
    """Drop all data from the database."""
    if _conn is None:
        return
    # Get all node table names and delete data from each
    try:
        tables = await get_schema()
        for label in tables.get("labels", []):
            await execute_cypher(f"MATCH (n:{label}) DELETE n", collect=False)
    except Exception as e:
        logger.warning("Reset failed: %s", e)
