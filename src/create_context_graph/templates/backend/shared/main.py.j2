"""{{ domain.name }} Context Graph — FastAPI Application."""

from contextlib import asynccontextmanager

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from app.config import settings
from app.context_graph_client import connect_neo4j, close_neo4j
from app.routes import router


@asynccontextmanager
async def lifespan(app: FastAPI):
    """Manage application lifecycle."""
    await connect_neo4j()
    yield
    await close_neo4j()


app = FastAPI(
    title="{{ domain.name }} Context Graph",
    description="{{ domain.description }}",
    version="0.1.0",
    lifespan=lifespan,
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

app.include_router(router, prefix="/api")


@app.get("/health")
async def health():
    return {"status": "ok", "domain": "{{ domain.id }}"}
