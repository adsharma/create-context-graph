"""{{ domain.name }} Context Graph — FastAPI Application."""
{% raw %}
import logging
import os
from contextlib import asynccontextmanager

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from app.config import settings
from app.context_graph_client import connect_db, close_db, is_connected
from app.routes import router

logger = logging.getLogger(__name__)

# LadybugDB connection state
_db_available = False


@asynccontextmanager
async def lifespan(app: FastAPI):
    """Manage application lifecycle."""
    global _db_available
    try:
        await connect_db()
        _db_available = True
        logger.info("LadybugDB connected successfully")
    except Exception as e:
        _db_available = False
        logger.warning("LadybugDB unavailable — starting in degraded mode: %s", e)

    yield
    if _db_available:
        await close_db()


def get_db_status() -> bool:
    """Check if LadybugDB is available."""
    return _db_available

{% endraw %}
app = FastAPI(
    title="{{ domain.name }} Context Graph",
    description="{{ domain.description }}",
    version="0.1.0",
    lifespan=lifespan,
)

{% raw %}
CORS_ORIGINS = os.getenv(
    "CORS_ORIGINS",
    f"http://localhost:{settings.frontend_port}",
).split(",")

app.add_middleware(
    CORSMiddleware,
    allow_origins=CORS_ORIGINS,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

app.include_router(router, prefix="/api")


@app.get("/health")
{% endraw %}
async def health():
    """Health check endpoint with LadybugDB connectivity status."""
    db_ok = is_connected()
    return {
        "status": "ok" if db_ok else "degraded",
        "ladybugdb": db_ok,
        "domain": "{{ domain.id }}",
        "version": "0.1.0",
    }
