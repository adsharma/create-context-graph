{% raw %}
from contextlib import asynccontextmanager

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware

from app.config import settings
from app.context_graph_client import connect_neo4j, close_neo4j
from app.routes import router


@asynccontextmanager
async def lifespan(app: FastAPI):
    """Manage application lifecycle."""
    await connect_neo4j()

    # Create vector indexes if supported (Neo4j 5.13+)
    try:
        from app.vector_client import create_vector_index
        await create_vector_index()
    except Exception:
        pass  # Vector indexes are optional

    yield
    await close_neo4j()

{% endraw %}
app = FastAPI(
    title="{{ domain.name }} Context Graph",
    description="{{ domain.description }}",
    version="0.1.0",
