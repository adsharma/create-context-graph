{% raw %}
from __future__ import annotations

import asyncio
import json
from pathlib import Path

from app.config import settings
from app.context_graph_client import connect_db, close_db, execute_cypher


DATA_DIR = Path(__file__).parent.parent.parent / "data"


async def apply_schema():
    """Apply the Cypher schema (CREATE NODE TABLE / CREATE REL TABLE)."""
    schema_path = Path(__file__).parent.parent.parent / "cypher" / "schema.cypher"
    if schema_path.exists():
        schema = schema_path.read_text()
        for statement in schema.split(";"):
            stmt = statement.strip()
            if stmt and not stmt.startswith("//"):
                try:
                    await execute_cypher(stmt)
                    print(f"  Applied: {stmt[:60]}...")
                except Exception as e:
                    if "already exists" not in str(e).lower():
                        print(f"  Warning: {e}")


async def load_fixture_data(data: dict):
    """Load entities and relationships from fixture data."""
    # Create entities
    entities = data.get("entities", {})
    for label, items in entities.items():
        for item in items:
            props = ", ".join(f"{k}: ${k}" for k in item.keys())
            cypher = f"CREATE (n:{label} {{{props}}})"
            try:
                await execute_cypher(cypher, item)
            except Exception as e:
                print(f"  Warning creating {label}: {e}")
        print(f"  Created {len(items)} {label} nodes")

    # Create relationships
    relationships = data.get("relationships", [])
    for rel in relationships:
        cypher = (
            f"MATCH (a:{rel['source_label']}), (b:{rel['target_label']}) "
            f"WHERE a.name = $source_name AND b.name = $target_name "
            f"CREATE (a)-[:{rel['type']}]->(b)"
        )
        try:
            await execute_cypher(cypher, {
                "source_name": rel["source_name"],
                "target_name": rel["target_name"],
            })
        except Exception as e:
            print(f"  Warning creating relationship: {e}")
    print(f"  Created {len(relationships)} relationships")


async def load_documents(data: dict):
    """Load documents into the graph."""
    documents = data.get("documents", [])
    if not documents:
        print("  No documents to load")
        return

    for doc in documents:
        cypher = """
        CREATE (d:Document {
            title: $title,
            content: $content,
            template_id: $template_id,
            template_name: $template_name
        })
        """
        try:
            await execute_cypher(cypher, {
                "title": doc.get("title", ""),
                "content": doc.get("content", ""),
                "template_id": doc.get("template_id", ""),
                "template_name": doc.get("template_name", ""),
            })
        except Exception as e:
            print(f"  Warning creating document: {e}")

    print(f"  Created {len(documents)} Document nodes")


async def load_decision_traces(data: dict):
    """Load decision traces with their reasoning steps."""
    traces = data.get("traces", [])
    if not traces:
        print("  No decision traces to load")
        return

    for trace in traces:
        # Create trace node
        try:
            await execute_cypher(
                "CREATE (t:DecisionTrace {id: $id, task: $task, outcome: $outcome})",
                {
                    "id": trace.get("id", ""),
                    "task": trace.get("task", ""),
                    "outcome": trace.get("outcome", ""),
                },
            )
        except Exception as e:
            print(f"  Warning creating trace: {e}")
            continue

        # Create steps and link to trace
        for i, step in enumerate(trace.get("steps", [])):
            try:
                trace_id = trace.get("id", "")
                step_id = f"{trace_id}_step_{i+1}"
                await execute_cypher(
                    "CREATE (s:TraceStep {"
                    "trace_step_id: $step_id, trace_id: $trace_id, "
                    "step_number: $step_number, thought: $thought, "
                    "action: $action, observation: $observation})",
                    {
                        "step_id": step_id,
                        "trace_id": trace_id,
                        "step_number": i + 1,
                        "thought": step.get("thought", ""),
                        "action": step.get("action", ""),
                        "observation": step.get("observation", ""),
                    },
                )
                # Link step to trace
                await execute_cypher(
                    "MATCH (t:DecisionTrace), (s:TraceStep) "
                    "WHERE t.id = $trace_id AND s.trace_step_id = $step_id "
                    "CREATE (t)-[:HAS_STEP]->(s)",
                    {"trace_id": trace_id, "step_id": step_id},
                )
            except Exception as e:
                print(f"  Warning creating trace step: {e}")

    print(f"  Created {len(traces)} DecisionTrace nodes with steps")
{% endraw %}

async def main():
    print("Seeding {{ domain.name }} context graph...")
    await connect_db()

{% raw %}
    # Load fixture data
    fixture_path = DATA_DIR / "fixtures.json"
    if not fixture_path.exists():
        print("No fixture data found. Create data/fixtures.json to seed data.")
        await close_db()
        return

    data = json.loads(fixture_path.read_text())
{% endraw %}

    print("\n[1/4] Applying schema...")
    await apply_schema()

    print("\n[2/4] Loading entities and relationships...")
{% raw %}
    await load_fixture_data(data)
{% endraw %}

    print("\n[3/4] Loading documents...")
{% raw %}
    await load_documents(data)
{% endraw %}

    print("\n[4/4] Loading decision traces...")
{% raw %}
    await load_decision_traces(data)

    await close_db()
{% endraw %}
    print("\nDone! Your {{ domain.name }} context graph is ready.")


if __name__ == "__main__":
    asyncio.run(main())
