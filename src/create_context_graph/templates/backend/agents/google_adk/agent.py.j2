{% raw %}
def run_cypher(query: str, parameters: str = "{}") -> str:
    """Execute a read-only Cypher query against the knowledge graph."""
    import asyncio
    params = json.loads(parameters) if parameters else {}
    result = asyncio.run(execute_cypher(query, params))
    return json.dumps(result, default=str)


def get_graph_schema() -> str:
    """Get the knowledge graph schema (node labels and relationship types)."""
    import asyncio
    result = asyncio.run(get_schema())
    return json.dumps(result, default=str)
{% endraw %}

agent = Agent(
    name="{{ domain.id }}_agent",
    model="gemini-2.0-flash",
    instruction=SYSTEM_PROMPT,
    tools=[
{% for tool in agent_tools %}
        FunctionTool({{ tool.name }}),
{% endfor %}
        FunctionTool(run_cypher),
        FunctionTool(get_graph_schema),
    ],
)

{% raw %}
# ---------------------------------------------------------------------------
# Message handler
# ---------------------------------------------------------------------------


async def handle_message(message: str, session_id: str | None = None) -> dict:
    """Handle an incoming chat message."""
    if session_id is None:
        session_id = str(uuid.uuid4())

    from google.adk.runners import Runner
    from google.adk.sessions import InMemorySessionService

    session_service = InMemorySessionService()
    runner = Runner(agent=agent, app_name="context-graph", session_service=session_service)

    session = await session_service.create_session(
        app_name="context-graph", user_id=session_id
    )

    from google.genai import types
    content = types.Content(
        role="user", parts=[types.Part.from_text(message)]
    )

    response_text = ""
    async for event in runner.run_async(
        user_id=session_id, session_id=session.id, new_message=content
    ):
        if hasattr(event, "text") and event.text:
            response_text += event.text

    return {
        "response": response_text or "No response generated.",
        "session_id": session_id,
        "graph_data": None,
    }
{% endraw %}
