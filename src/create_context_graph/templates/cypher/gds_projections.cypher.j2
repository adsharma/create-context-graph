// GDS Graph Projections for {{ domain.name }}
// Generated by create-context-graph
// Note: Requires LadybugDB (graph analytics not available)

// Full entity projection (all node labels and relationship types)
CALL gds.graph.project(
  '{{ domain.id | replace("-", "_") }}_full',
  [{% for et in entity_types %}'{{ et.label }}'{% if not loop.last %}, {% endif %}{% endfor %}],
  [{% for rel in relationships %}'{{ rel.type }}'{% if not loop.last %}, {% endif %}{% endfor %}]
);

// Community detection
CALL gds.louvain.write('{{ domain.id | replace("-", "_") }}_full', {
  writeProperty: 'community'
});

// PageRank centrality
CALL gds.pageRank.write('{{ domain.id | replace("-", "_") }}_full', {
  writeProperty: 'pagerank'
});

// FastRP embeddings for structural similarity
CALL gds.fastRP.write('{{ domain.id | replace("-", "_") }}_full', {
  embeddingDimension: 128,
  writeProperty: 'fastrp_embedding'
});

// Clean up projection
CALL gds.graph.drop('{{ domain.id | replace("-", "_") }}_full');
