# {{ domain.name }} Context Graph — Production Docker Compose
# Generated by create-context-graph
#
# LadybugDB is embedded — no database container needed.
#
# Usage:
#   docker compose -f docker-compose.prod.yml up --build -d

services:
  backend:
    build:
      context: ./backend
      dockerfile: ../Dockerfile.backend
    ports:
      - "${BACKEND_PORT:-8000}:8000"
    environment:
      LADYBUG_DB_PATH: /app/data/ladybug.db
{% if 'anthropic' in framework or framework == 'pydanticai' or framework == 'claude-agent-sdk' %}
      ANTHROPIC_API_KEY: ${ANTHROPIC_API_KEY}
{% endif %}
{% if 'openai' in framework or framework == 'langgraph' %}
      OPENAI_API_KEY: ${OPENAI_API_KEY}
{% endif %}
{% if framework == 'google-adk' %}
      GOOGLE_API_KEY: ${GOOGLE_API_KEY}
{% endif %}
{% if framework == 'strands' %}
      AWS_ACCESS_KEY_ID: ${AWS_ACCESS_KEY_ID:-}
      AWS_SECRET_ACCESS_KEY: ${AWS_SECRET_ACCESS_KEY:-}
      AWS_DEFAULT_REGION: ${AWS_DEFAULT_REGION:-us-east-1}
{% endif %}
      CORS_ORIGINS: http://localhost:${FRONTEND_PORT:-3000}
    volumes:
      - ladybug_data:/app/data

  frontend:
    build:
      context: ./frontend
      dockerfile: ../Dockerfile.frontend
      args:
        NEXT_PUBLIC_API_URL: http://localhost:${BACKEND_PORT:-8000}/api
    ports:
      - "${FRONTEND_PORT:-3000}:3000"
    depends_on:
      - backend

volumes:
  ladybug_data:
